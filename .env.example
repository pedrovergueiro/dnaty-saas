# ─── dNATY SaaS — template de configuração ────────────────────────────────────
# Copie para .env e preencha os valores antes de rodar.

API_KEY=
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["*"]

# ─── Claude / Anthropic ────────────────────────────────────────────────────────
# Gera explicacoes e codigo de deploy automaticamente apos cada compressao.
# Sem esta chave o sistema funciona, mas usa textos template no lugar.
ANTHROPIC_API_KEY=sk-ant-...

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# No Railway, DATABASE_URL é injetada automaticamente pelo plugin Postgres
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=gere-um-valor-aleatorio-aqui
JWT_EXPIRE_MINUTES=43200

# ─── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.dnaty.io
LANDING_URL=https://dnaty.io
